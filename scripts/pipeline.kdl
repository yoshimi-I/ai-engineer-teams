mouse_mode true

keybinds {
    locked {
        bind "Ctrl h" { MoveFocus "Left"; }
        bind "Ctrl j" { MoveFocus "Down"; }
        bind "Ctrl k" { MoveFocus "Up"; }
        bind "Ctrl l" { MoveFocus "Right"; }
    }
    normal {
        bind "Ctrl h" { MoveFocus "Left"; }
        bind "Ctrl j" { MoveFocus "Down"; }
        bind "Ctrl k" { MoveFocus "Up"; }
        bind "Ctrl l" { MoveFocus "Right"; }
    }
}

layout {
    cwd "__PROJECT_CWD__"
    tab name="Pipeline" {
        pane command="bash" name="Orchestrator" {
            args "-c" "./scripts/orchestrator.sh"
        }
    }
    tab name="Operator" {
        pane command="bash" name="Operator" {
            args "-c" "./scripts/operator.sh"
        }
    }
    tab name="Agents" {
        pane command="bash" name="Agent Area" {
            args "-c" "echo 'Agent panes will be created here by the orchestrator.'; while true; do sleep 3600; done"
        }
    }
    tab name="Control" {
        pane command="bash" name="Control Panel" {
            args "-c" "./scripts/control-panel.sh"
        }
    }
}
